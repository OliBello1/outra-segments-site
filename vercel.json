{
  "buildCommand": "node build.js",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/render.js": { "includeFiles": "builder-template.html" },
    "api/render-preview.js": { "includeFiles": "builder-template.html" },
    "api/pricing-view.js": { "includeFiles": "{builder-template.html,builder-template-proposal.html}" }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/alpha",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/signature-segments/DirectMail", "destination": "https://outra-directmail.vercel.app/" },
    { "source": "/signature-segments/DirectMail/:path*", "destination": "https://outra-directmail.vercel.app/:path*" },
    { "source": "/signature-segments/directmail", "destination": "https://outra-directmail.vercel.app/" },
    { "source": "/signature-segments/directmail/:path*", "destination": "https://outra-directmail.vercel.app/:path*" },

    { "source": "/open-partners", "destination": "/open-partners.html" },
    { "source": "/dentsu", "destination": "/dentsu.html" },
    { "source": "/omnicom", "destination": "/omnicom.html" },
    { "source": "/mercedes-amg-f1", "destination": "/mercedes-amg-f1.html" },
    { "source": "/uber", "destination": "/uber.html" },
    { "source": "/Outra-Platform", "destination": "/outra-platform.html" },
    { "source": "/Outra%20Platform", "destination": "/outra-platform.html" },
    { "source": "/Outra Platform", "destination": "/outra-platform.html" },
    { "source": "/outra-platform", "destination": "/outra-platform.html" },
    { "source": "/signature-segments/Outra-Platform", "destination": "/outra-platform.html" },
    { "source": "/signature-segments/Outra%20Platform", "destination": "/outra-platform.html" },
    { "source": "/signature-segments/Outra Platform", "destination": "/outra-platform.html" },

    { "source": "/signature-segments", "destination": "/index.html" },
    { "source": "/signature-segments/price", "destination": "/price.html" },
    { "source": "/signature-segments/pricing", "destination": "/price.html" },
    { "source": "/signature-segments/big-green-egg", "destination": "/big-green-egg.html" },
    { "source": "/signature-segments/dentsu", "destination": "/dentsu.html" },
    { "source": "/signature-segments/mercedes-amg-f1", "destination": "/mercedes-amg-f1.html" },
    { "source": "/signature-segments/omnicom", "destination": "/omnicom.html" },
    { "source": "/signature-segments/open-partners", "destination": "/open-partners.html" },
    { "source": "/signature-segments/rathbones", "destination": "/rathbones.html" },
    { "source": "/signature-segments/uber", "destination": "/uber.html" },
    { "source": "/signature-segments/Purplebricks", "destination": "/Purplebricks.html" },
    { "source": "/signature-segments/purplebricks", "destination": "/Purplebricks.html" },
    { "source": "/signature-segments/PurpleBricks", "destination": "/Purplebricks.html" },

    {
      "source": "/signature-segments/Channel Logos/:path*",
      "destination": "/Channel Logos/:path*"
    },
    {
      "source": "/signature-segments/Company Logos/:path*",
      "destination": "/Company Logos/:path*"
    },
    {
      "source": "/signature-segments/Header.mp4",
      "destination": "/Header.mp4"
    },
    {
      "source": "/signature-segments/logo Transparent.png",
      "destination": "/logo Transparent.png"
    },

    { "source": "/signature-segments/:brand", "destination": "/api/render?brand=:brand" },

    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/favicon-16.png", "destination": "/favicon-16.png" },
    { "source": "/favicon-32.png", "destination": "/favicon-32.png" },
    { "source": "/favicon-256.png", "destination": "/favicon-256.png" },
    { "source": "/apple-touch-icon.png", "destination": "/apple-touch-icon.png" },

    { "source": "/alpha", "destination": "/alpha/index.html" },
    { "source": "/PBROI", "destination": "/PBROI/index.html" },
    { "source": "/PricingView", "destination": "/api/pricing-view" },

    { "source": "/home", "destination": "/home/index.html" },
    { "source": "/home/", "destination": "/home/index.html" },
    { "source": "/home/platform", "destination": "/home/platform/index.html" },
    { "source": "/home/platform/", "destination": "/home/platform/index.html" },
    { "source": "/home/solutions", "destination": "/home/solutions/index.html" },
    { "source": "/home/solutions/", "destination": "/home/solutions/index.html" },
    { "source": "/home/insights", "destination": "/home/insights/index.html" },
    { "source": "/home/insights/", "destination": "/home/insights/index.html" },
    { "source": "/home/:path*", "destination": "/home/:path*" },

    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "trailingSlash": false
}
